{
  "name": "agent-cli",
  "displayName": "Agent CLI Tracker",
  "version": "1.0.0",
  "description": "Track agent CLI commands, identify patterns, and install aliases to the host shell.",
  "author": "Tom Wu",
  "license": "MIT",
  "platforms": ["hermes", "openclaw", "claude-code"],
  "category": "productivity",
  "tags": ["cli", "aliases", "shell", "productivity", "tracking"],
  "repository": "https://github.com/your/agent-cli",
  "commands": {
    "track": "/track",
    "track-top": "/track --top",
    "track-patterns": "/track --patterns",
    "track-install": "/track --install"
  },
  "hooks": {
    "PostToolUse": {
      "Bash": "${AGENT_CLI_ROOT}/hooks/command-track.sh"
    }
  }
}