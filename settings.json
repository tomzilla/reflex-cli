{
  "name": "reflex-cli",
  "displayName": "Reflex CLI",
  "version": "1.0.0",
  "description": "Track agent CLI commands, identify patterns, and install aliases to the host shell.",
  "author": "Tom Wu",
  "license": "MIT",
  "platforms": [
    "hermes",
    "openclaw",
    "claude-code"
  ],
  "category": "productivity",
  "tags": [
    "cli",
    "aliases",
    "shell",
    "productivity",
    "tracking"
  ],
  "repository": "https://github.com/your/reflex-cli",
  "commands": {
    "reflex": "/reflex",
    "reflex-top": "/reflex --top",
    "reflex-patterns": "/reflex --patterns",
    "reflex-install": "/reflex --install"
  },
  "hooks": {
    "PostToolUse": {
      "Bash": "${REFLEX_CLI_ROOT}/hooks/command-track.sh"
    }
  }
}